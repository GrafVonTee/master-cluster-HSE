FROM unsloth/unsloth:2026.4.8-pt2.10.0-vllm-0.16.0-cu12.8-studio-release-v0.1.37-beta-fix-startup

WORKDIR /workspace

ENV PROJECT_DIR=/workspace
ENV PYTHONPATH=/workspace
ENV HF_HOME=/workspace/.cache/huggingface
ENV HF_DATASETS_CACHE=/workspace/.cache/hf_datasets
ENV VLLM_CACHE_ROOT=/workspace/.cache/vllm
ENV TOKENIZERS_PARALLELISM=false

RUN python -m pip install --no-cache-dir \
    jupyterlab \
    ipykernel \
    ipywidgets \
    tensorboard \
    pandas \
    pyarrow \
    pyyaml \
    tabulate

CMD ["/bin/bash"]
